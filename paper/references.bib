%% ---- 10. Contagion Path Prediction ----

@article{wu2024contagion,
  title={Contagion path prediction in financial enterprise networks},
  author={Wu, Xiaotong and others},
  journal={Informatica},
  year={2024},
  abstract={We propose a contagion path prediction algorithm based on deep learning frameworks designed to capture both direct and indirect transmission of financial risks across enterprise networks. The approach uses improved Self-Attention Graph Neural Networks to model cascading effects in guarantee and investment networks among listed companies.}
}

%% ---- 11. Additional Risk Network Studies ----

@article{niu2020evolving,
  title={Evolution of the {Chinese} guarantee network under financial crisis and stimulus program},
  author={Niu, Zibo and others},
  journal={PLoS ONE},
  volume={15},
  number={6},
  pages={e0232658},
  year={2020},
  abstract={This paper analyzes the evolution of the Chinese corporate guarantee network from 2007 to 2015, covering the global financial crisis and China's fiscal stimulus. We find that the guarantee network exhibits power-law degree distributions and small-world properties, and that the stimulus program significantly altered network topology, increasing interconnectedness and potential systemic risk.}
}

@article{wang2019risk,
  title={Risk contagion caused by interactions between credit and guarantee networks},
  author={Wang, Xiaoming and others},
  journal={Physica A: Statistical Mechanics and its Applications},
  volume={539},
  pages={122890},
  year={2020},
  publisher={Elsevier},
  abstract={This paper investigates risk contagion caused by the interactions between credit networks and guarantee networks. Using empirical data from Chinese listed companies, we demonstrate that the coupling of these two networks amplifies systemic risk and identify key topological factors that drive contagion dynamics.}
}

%% ---- 12. Additional Key References (added) ----

@inproceedings{cheng2020contagion,
  title={Risk guarantee prediction in networked-loans},
  author={Cheng, Dawei and Wang, Xiaoyang and Zhang, Ying and Zhang, Liqing},
  booktitle={Proceedings of the 29th International Joint Conference on Artificial Intelligence (IJCAI)},
  pages={4483--4489},
  year={2020},
  abstract={This paper proposes a Dynamic Graph-based Attention Neural Network (DGANN) for risk guarantee prediction in networked-loans. The model integrates a GCN encoder with structure attention to capture cross-company risk propagation and a GRN encoder with temporal attention to model dynamic risk evolution. Experiments on a real-world networked-loan dataset demonstrate that DGANN significantly outperforms baselines including DeepWalk, GCN, GAT, and LSTM, achieving over 85\% AUC in identifying high-risk guarantee chains.}
}

@article{cheng2022contagion,
  title={Regulating systemic crises: Stemming the contagion risk in networked-loans through deep graph learning},
  author={Cheng, Dawei and Niu, Zhibin and Zhang, Jianfu and Zhang, Yiyi and Zhang, Ying},
  journal={IEEE Transactions on Knowledge and Data Engineering},
  volume={35},
  number={6},
  pages={6279--6292},
  year={2023},
  publisher={IEEE},
  abstract={The networked-guarantee-loan crisis has drawn significant attention from both academic and industry communities. This paper proposes iConReg, a deep graph learning framework for regulating systemic crises in networked-loans. The framework integrates node-level risk encoding, graph-level contagion modeling, and a temporal attention mechanism to detect early-stage contagion and identify high-risk nodes whose isolation could effectively reduce system-wide default rates by 25.8\%. Experiments on a nationwide dataset demonstrate superior performance with AUC exceeding 91\%.}
}

@inproceedings{zheng2023qtiah,
  title={{QTIAH-GNN}: Quantity and topology imbalance-aware heterogeneous graph neural network for bankruptcy prediction},
  author={Zheng, Yucheng and others},
  booktitle={Proceedings of the 29th ACM SIGKDD Conference on Knowledge Discovery and Data Mining},
  pages={3526--3537},
  year={2023},
  abstract={We propose QTIAH-GNN for bankruptcy prediction that addresses both quantity-imbalance (long-tail class distribution) and topology-imbalance (message-passing dominated by majority-class neighbors) simultaneously. The model introduces a multi-hierarchy label-aware neighbor selection strategy and an imbalance-oriented loss function. Experiments on a real-world corporate relationship dataset demonstrate that QTIAH-GNN consistently outperforms state-of-the-art baselines by significant margins.}
}

@article{zandi2024attention,
  title={Attention-based dynamic multilayer graph neural networks for loan default prediction},
  author={Zandi, Gholamreza and Korangi, Kamesh and Oskarsdottir, Maria and Mues, Christophe and Bravo, Cristian},
  journal={European Journal of Operational Research},
  volume={320},
  number={2},
  pages={429--443},
  year={2025},
  publisher={Elsevier},
  abstract={This paper proposes a dynamic multilayer graph neural network model for loan default prediction. The model combines graph attention mechanisms with LSTM networks to capture both spatial dependencies across multiple network layers and temporal dynamics. Using mortgage loan data from Freddie Mac, the multilayer dynamic approach consistently outperforms single-layer and static baselines, with the attention mechanism enabling interpretable temporal weighting of historical snapshots.}
}

@article{niu2020guarantee,
  title={Unveiling the evolution of the {Chinese} guarantee network and the impact of the financial crisis and stimulus program},
  author={Niu, Zhibin and Cheng, Dawei and Zhang, Liqing and Zhang, Jiawan},
  journal={Nature Communications},
  volume={11},
  pages={2972},
  year={2020},
  publisher={Nature Publishing Group},
  abstract={We construct a comprehensive dataset of corporate guarantee relationships in China from 2007 to 2015 and analyze the network's topological evolution. The guarantee network exhibits scale-free and small-world properties. The global financial crisis stabilized the network structure, while the 4-trillion-yuan stimulus program significantly increased interconnectedness, creating fragile mutual-guarantee structures that amplified systemic risk. These findings have important implications for financial regulation.}
}

@article{ohlson1980financial,
  title={Financial ratios and the probabilistic prediction of bankruptcy},
  author={Ohlson, James A},
  journal={Journal of Accounting Research},
  volume={18},
  number={1},
  pages={109--131},
  year={1980},
  publisher={JSTOR},
  abstract={This study uses a conditional logit model for predicting bankruptcy, employing data from 1970 to 1976. Four basic factors were found to be statistically significant in affecting the probability of failure: the size of the company, a measure of the financial structure, a performance measure, and a measure of current liquidity. The O-score model complements the Altman Z-score by using a logistic regression framework.}
}

@article{duan2012multiperiod,
  title={Multiperiod corporate default prediction---A forward intensity approach},
  author={Duan, Jin-Chuan and Sun, Jie and Wang, Tao},
  journal={Journal of Econometrics},
  volume={170},
  number={1},
  pages={191--209},
  year={2012},
  publisher={Elsevier},
  abstract={This paper develops a forward intensity model for multiperiod corporate default prediction. The model accounts for time-varying default intensities influenced by firm-specific and macroeconomic covariates, supporting multi-year ahead prediction. The forward intensity approach provides a theoretically consistent framework and achieves strong out-of-sample prediction accuracy on a comprehensive U.S. corporate database.}
}

@inproceedings{schlichtkrull2018modeling,
  title={Modeling relational data with graph convolutional networks},
  author={Schlichtkrull, Michael and Kipf, Thomas N and Bloem, Peter and Van Den Berg, Rianne and Titov, Ivan and Welling, Max},
  booktitle={European Semantic Web Conference},
  pages={593--607},
  year={2018},
  publisher={Springer},
  abstract={We introduce Relational Graph Convolutional Networks (R-GCNs) for modeling relational data. R-GCNs extend graph convolutional networks to handle multi-relational data by learning relation-specific weight matrices with basis or block-diagonal decomposition for parameter sharing. We apply R-GCNs to link prediction and entity classification on knowledge bases, demonstrating competitive results on standard benchmarks while providing a scalable approach to relational reasoning.}
}
